<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ChipButtonStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/mainPurple</item>
        <item name="strokeColor">@color/mainPurple</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">15dp</item>
        <item name="android:fontFamily">@font/montserrat_bold</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>
</resources>