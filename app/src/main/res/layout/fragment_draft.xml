<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_white_90"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="#DDDDDD"
        android:backgroundTint="#DDDDDD" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="Draft Pesanan"
            android:textColor="#333333"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btnCloseDraft"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_white_rounded_stroke"
            android:gravity="center"
            android:text="✕"
            android:textColor="#666666"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBarDraft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginVertical="32dp"
        android:visibility="gone" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmptyDraft"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="48dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📭"
            android:textSize="40sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tidak ada draft hari ini"
            android:textColor="#9E9E9E"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Draft list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDrafts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="480dp"
        android:nestedScrollingEnabled="false"
        android:visibility="gone" />

</LinearLayout>